{
  "permissions": {
    "allow": [
      "Read(/Users/hamid.sajjadi/repos/**)",
      "mcp__claude_ai_Atlassian__*",
      "mcp__nolo__execute_script",
      "mcp__nolo__connection_status",
      "mcp__nolo__current_profile",
      "mcp__nolo__list_profiles",
      "mcp__nolo__switch_profile_readonly"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "andrej-karpathy-skills@karpathy-skills": true
  },
  "extraKnownMarketplaces": {
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    }
  },
  "effortLevel": "high",
  "theme": "light-ansi",
  "skipAutoPermissionPrompt": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude is done\" with title \"Claude Code\"' 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
